public void rearrange(int[] arr) {
    int even = 0;
    for (int i = 0; i < arr.length; i++) {
        if (arr[i] % 2 == 0) {
            int temp = arr[i];
            arr[i] = arr[even];
            arr[even] = temp;
            even += 1; // Move to next even position or similar logic based on requirement
        }
    }
}
