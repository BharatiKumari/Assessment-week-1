public int findBound(int[] arr, int target, boolean isFirst) {
    int low = 0, high = arr.length - 1, res = -1;
    while (low <= high) {
        int mid = low + (high - low) / 2;
        if (arr[mid] == target) {
            res = mid;
            if (isFirst) high = mid - 1;
            else low = mid + 1;
        } else if (arr[mid] < target) low = mid + 1;
        else high = mid - 1;
    }
    return res;
}
